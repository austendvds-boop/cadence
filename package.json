{
  "name": "cadence",
  "version": "1.0.0",
  "description": "DVDS custom AI voice agent",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx db/migrate.ts",
    "db:seed:dvds": "tsx scripts/seed-dvds-client.ts",
    "db:reset:onboarding": "tsx scripts/reset-onboarding-client.ts",
    "smoke:onboarding": "tsx scripts/smoke-onboarding.ts",
    "smoke:tenant-clone": "tsx scripts/smoke-tenant-clone.ts",
    "tenant:rebase": "tsx scripts/rebase-tenant-from-baseline.ts",
    "tenant:verify": "tsx scripts/verify-tenant-baseline.ts"
  },
  "author": "Steve",
  "license": "MIT",
  "dependencies": {
    "@deepgram/sdk": "^4.11.3",
    "alawmulaw": "^6.0.0",
    "axios": "^1.12.2",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.1",
    "openai": "^6.7.0",
    "pg": "^8.19.0",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.2",
    "stripe": "^20.4.0",
    "twilio": "^5.10.4",
    "ws": "^8.18.3",
    "xmlbuilder2": "^4.0.0",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.11",
    "@types/pg": "^8.18.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  }
}
